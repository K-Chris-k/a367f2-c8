{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}
<style>
    #shopify-section-{{ section.id }} .rich-text-list-section{padding-top: {{ section.settings.padding_top }}px;padding-bottom: {{ section.settings.padding_bottom }}px;}
    #shopify-section-{{ section.id }} .rich-text{flex-flow: column;}
    #shopify-section-{{ section.id }} p{ font-family: 'Inter';line-height:22px; font-size:18px;color: #666;}
    #shopify-section-{{ section.id }} .image-wrapper-container{margin:0px;}
    #shopify-section-{{ section.id }} .image-wrapper-container .image-wrapper{margin-top:{{ section.settings.image_top }}px}
    #shopify-section-{{ section.id }} .details-box{gap:168px}
    #shopify-section-{{ section.id }} .details-box .item{display: flex;flex-flow: column;}
    #shopify-section-{{ section.id }} .details-box strong{line-height: 44px;font-weight: 700;font-size: 36px;background: linear-gradient(180deg, #3250C3 0%, #91AFFA 100%);
    -webkit-background-clip: text;-webkit-text-fill-color: transparent;}
    #shopify-section-{{ section.id }} .details-box span{line-height: 22px;font-size: 18px}
    #shopify-section-{{ section.id }} .h3{font-size: 30px;line-height: 36px;font-weight: 500;}
    #shopify-section-{{ section.id }} .text-base p{ font-family: 'Inter'; line-height: 17px;font-size:14px; }
    #shopify-section-{{ section.id }} .container-full {width: 100vw;margin-left: calc(-50vw + 50%);}
    #shopify-section-{{ section.id }} .container-full .grid-image {width: 100%;height: auto;object-fit: contain; }
    #shopify-section-{{ section.id }} .grid-image { width: revert-layer;height: auto;object-fit: contain; }

  
    #shopify-section-{{ section.id }} .hd2 strong{display:block}
    
      #shopify-section-{{ section.id }} .icon-gift{ width: 3rem; height: 3rem;margin: 0px 10px;}

      #shopify-section-{{ section.id }} .title-container {
  display: flex;
  align-items: center;  /* 关键：垂直居中 */
  justify-content: center;
  gap: 0px;  /* 控制间距 */
}

#shopify-section-{{ section.id }} .icon-gift {
  flex-shrink: 0;  /* 防止SVG被压缩 */
  color: #333;
}

#shopify-section-{{ section.id }} h2 {
  margin: 0;  /* 移除默认边距 */
  flex: 1;  /* 让h2占据剩余空间 */
}

   #shopify-section-{{ section.id }} .video_desk_show{ display:block; }
   #shopify-section-{{ section.id }} .video_mobile_show{ display:none;}
   #shopify-section-{{ section.id }} .video-width-image-section{padding-top:40px;}
   #shopify-section-{{ section.id }} video{ 
     width: 90%;
  height: 100%;;
  object-fit: contain; 
}

  #shopify-section-{{ section.id }} .video_desk_show .media {
    {% comment %} aspect-ratio:32/15; {% endcomment %}
  }

  #shopify-section-{{ section.id }} .input-width-custom{
    max-height:{{ section.settings.video-height-custom }}px; 
  }

   @media (max-width: 767.98px) {
    {% if section.settings.video_mobile != blank %}
         #shopify-section-{{ section.id }} .video_desk_show{ display:none;!important}
         #shopify-section-{{ section.id }} .video_mobile_show{ display:block;!important}
         #shopify-section-{{ section.id }} .video_mobile_show .media{ height:200px}
         #shopify-section-{{ section.id }} .video-width-image-section{padding-top:30px;}
         
    {% endif %}
   }

  @media (max-width: 767.98px) {
      #shopify-section-{{ section.id }} .rich-text-list-section{padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;padding-bottom: {{ section.settings.padding_bottom | divided_by: 2}}px;}
      #shopify-section-{{ section.id }} .image-wrapper-container .image-wrapper{margin-top:{{ section.settings.image_top | divided_by: 2 }}px}
      #shopify-section-{{ section.id }} .image-with-text__inner{padding:0px}
      #shopify-section-{{ section.id }} .rich-text__heading{ line-height:34px;font-size:28px}
      #shopify-section-{{ section.id }} p{ line-height:19px;font-size:16px;}
      #shopify-section-{{ section.id }} .details-box{gap:65px}
      #shopify-section-{{ section.id }} .details-box strong{line-height: 22px;font-size: 18px}
      #shopify-section-{{ section.id }} .details-box span{line-height: 15px;font-size: 12px;color: #303030;}
      #shopify-section-{{ section.id }} .h3{font-size: 28px;line-height: 30px;}
      #shopify-section-{{ section.id }} .video-container-inner{ width: 200px!important;height:36px!important}
      #shopify-section-{{ section.id }} .video-container-custom { margin-top:3rem}
      #shopify-section-{{ section.id }} .video-popup-block {
        margin-top: 20px;
      }
      #shopify-section-{{ section.id }} .hd2{font-size:26px;}
      .close-button {
        top: -40px;
        font-size: 30px;
      }
          #shopify-section-{{ section.id }} .icon-gift{ width: 2rem; height: 1.5rem;}
    #shopify-section-{{ section.id }} .icon-gift-left{ margin: 0px 0px 0px 50px;}
    #shopify-section-{{ section.id }} .icon-gift-right{ margin: 0px 50px 0px 0px;}

    #shopify-section-{{ section.id }} .title-container {
      margin: 0px 0px;
    }
  }
</style>
{%- assign motion_delay = 50 -%}
<div class="section section--padding rich-text-list-section color-{{ section.settings.color_scheme }}" id="{{section.settings.ids}}" style="background-color: {{ section.settings.bg_color }};">
  <div class="rich-text-list">
    <div class="rich-text  md:flex items-{{ section.settings.content_alignment }} text-{{ section.settings.mobile_content_alignment }} md:text-{{ section.settings.content_alignment }}">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'subheading' %}
            <motion-element
              data-motion="fade-up"
              data-motion-delay="{{ motion_delay }}"
              class="block page-width rich-text__subheading text-subheading"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.subheading }}
            </motion-element>  

            {%- assign motion_delay = motion_delay | plus: 50 -%}
          {% when 'heading' %}
             <div class="flex items-center  " style="justify-content: center;">
            <div class="{% if section.settings.show_title_icon != true %} page-width {% endif %}title-container">
                   {% if section.settings.show_title_icon != false %}
                   {% render 'icon-gift-left' -%}
                 {% endif %}
            <h2
              class=" rich-text__heading {{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              <motion-element class="block" data-motion="fade-up" data-motion-delay="{{ motion_delay }}">
          
                {% render 'highlight-text',
                  text: block.settings.heading,
                  style: block.settings.heading_highlight_style
                %}
       
              </motion-element>
            </h2>
                     {% if section.settings.show_title_icon != false %}
                   {% render 'icon-gift-right' -%}
                 {% endif %}
            </div>
            </div>
            {%- assign motion_delay = motion_delay | plus: 50 -%}
          {% when 'text' %}
            <motion-element
              data-motion="fade-up"
              data-motion-delay="{{ motion_delay }}"
              class="block page-width rich-text__text rte {{ block.settings.text_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </motion-element>
            {%- assign motion_delay = motion_delay | plus: 50 -%}
          {% when 'details' %}
            <motion-element
              data-motion="fade-up"
              data-motion-delay="{{ motion_delay }}"
              class="block page-width rich-text__text rte {{ block.settings.text_size }}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.details1 != blank or block.settings.detail1_description != blank %}
                <div class="flex justify-center details-box">
                  <div class="item">
                    <strong> {{ block.settings.details1 }}</strong
                    ><span>{{ block.settings.detail1_description }} </span>
                  </div>
                  <div class="item">
                    <strong> {{ block.settings.details2 }}</strong
                    ><span>{{ block.settings.detail2_description }} </span>
                  </div>
                </div>
              {% endif %}
            </motion-element>
          {% when 'button' %}
            <motion-element
              class="block page-width "
              data-motion="fade-up"
              data-motion-delay="{{ motion_delay }}"
            >
              {% if block.settings.button_label != blank %}
                <a
                  {% if block.settings.button_link != blank %}
                    href="{{ block.settings.button_link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                  class="btn {{ block.settings.button_style }}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.button_label -}}
                </a>
              {% endif %}
            </motion-element>
            {%- assign motion_delay = motion_delay | plus: 50 -%}
          {% endcase %}
      {% endfor %}
    </div>









<div class="video-width-image-section">
  <div class="section-video section--padding" id="{{section.settings.ids}}">
    <div class="relative{% if section.settings.container == 'fixed' %} page-width {% else %} w-full {% endif %}">
      <!-- 桌面端视频 -->
      <div class="{% if section.settings.enable_radius %}blocks-radius{% endif %} video_desk_show">
        <parallax-element
          class="block overflow-hidden input-width-custom"  
          {% if section.settings.enable_parallax %}
            data-parallax="0.3" data-parallax-direction="{{ section.settings.parallax_direction }}"
          {% endif %}
        >
          <motion-element data-motion="zoom-out" class="relative block media media--adapt">
            {%- capture sizes -%}{% if section.settings.container == 'full' %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
            {% assign device_type = section.settings.video %}
            {%-
              render 'video',
              sizes: sizes,
              video: {{device_type}},
              video_url: section.settings.video_url,
              muted: section.settings.enable_video_autoplay,
              autoplay: section.settings.enable_video_autoplay,
              controls: false,
              loop: section.settings.enable_video_looping,
              description: section.settings.description,
              cover_image: section.settings.cover_image,
              show_play_button: true
            -%}
          </motion-element>
        </parallax-element>
      </div>

      <!-- 移动端视频 -->
      {% if section.settings.video_mobile != blank %}
        <div class="{% if section.settings.enable_radius %}blocks-radius{% endif %} video_mobile_show">
          <parallax-element
            class="block overflow-hidden"
            {% if section.settings.enable_parallax %}
              data-parallax="0.3" data-parallax-direction="{{ section.settings.parallax_direction }}"
            {% endif %}
          >
            <motion-element data-motion="zoom-out" class="relative block media">
              {%- capture sizes -%}{% if section.settings.container == 'full' %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
              {% assign device_type = section.settings.video_mobile %}
              {%- if block.settings.video_mobile != blank -%}
                {% assign device_type = section.settings.video_mobile %}
              {% endif %}
              {%-
                render 'video',
                sizes: sizes,
                video: {{device_type}},
                video_mobile:section.settings.video_mobile,
                video_url: section.settings.video_url,
                muted: section.settings.enable_video_autoplay,
                autoplay: section.settings.enable_video_autoplay,
                controls: false,
                loop: section.settings.enable_video_looping,
                description: section.settings.description,
                cover_image: section.settings.cover_image,
                show_play_button: true
              -%}
            </motion-element>
          </parallax-element>
        </div>
      {% endif %}



    {% if section.settings.image_pc != blank %}
      <div class="image-wrapper">
        <picture>
          <!-- 移动端图片 -->
          <source
            media="(max-width: 749px)"
            srcset="
              {{ section.settings.image_mobile | img_url: '800x' }} 1x,
              {{ section.settings.image_mobile | img_url: '1600x' }} 2x
            "
          >

          <!-- 桌面端图片 -->
          <source
            media="(min-width: 750px)"
            srcset="
              {{ section.settings.image_pc | img_url: '1200x' }} 1x,
              {{ section.settings.image_pc | img_url: '2400x' }} 2x
            "
          >

          <!-- 默认图片 -->
          <img
            src="{{ section.settings.image_pc | img_url: '1200x' }}"
            alt="{{ section.settings.title | escape }}"
            class="service-image"
            loading="lazy"
            width="{{ section.settings.image_pc.width }}"
            height="{{ section.settings.image_pc.height }}"
          >
        </picture>
        </div>
      {% endif %}



    </div>
  </div>
  {% if section.settings.image != blank %}
   <div class="{% if section.settings.enable_radius %}blocks-radius {% endif %}video_mobile_show">
          <parallax-element
            class="block overflow-hidden"
            {% if section.settings.enable_parallax %}
              data-parallax="0.3" data-parallax-direction="{{ section.settings.parallax_direction }}"
            {% endif %}
          >
            <motion-element data-motion="zoom-out" class="relative block media">
              {%- capture sizes -%}{% if section.settings.container == 'full' %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
              {%- render 'video',
                sizes: sizes,
                video: section.settings.video_mobile,
                video_mobile: section.settings.video_mobile,
                video_url: section.settings.video_url,
                muted: section.settings.enable_video_autoplay,
                autoplay: section.settings.enable_video_autoplay,
                controls: false,
                loop: section.settings.enable_video_looping,
                description: section.settings.description,
                cover_image: section.settings.cover_image,
                show_play_button: true
              -%}
            </motion-element>
          </parallax-element>
        </div>
  {% endif %}
</div>
























  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const videoModal = document.querySelector('.video-modal');
    const videoPlayer = document.querySelector('.video-player');
    const closeBtn = document.querySelector('.close-button');

    // 关闭弹窗
    function closeModal() {
      videoModal.classList.remove('active');
      document.body.style.overflow = '';
      videoPlayer.innerHTML = '';
    }

    // 点击关闭按钮
    closeBtn.addEventListener('click', closeModal);

    // 点击模态框外部关闭
    videoModal.addEventListener('click', function (e) {
      if (e.target === videoModal) closeModal();
    });

    // 处理视频容器点击
    document.querySelectorAll('.video-container-inner').forEach((container) => {
      container.addEventListener('click', function () {
        const videoType = this.dataset.videoType;

        if (videoType === 'youtube') {
          const videoId = this.dataset.videoId;
          videoPlayer.innerHTML = `
          <iframe 
            src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen>
          </iframe>
        `;
        } else if (videoType === 'shopify') {
          const videoUrl = this.dataset.videoUrl;
          videoPlayer.innerHTML = `
          <video controls autoplay playsinline>
            <source src="${videoUrl}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        `;
        }

        videoModal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

     
  });
</script>
