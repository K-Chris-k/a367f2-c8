{{ 'component-scene-card.css' | asset_url | stylesheet_tag }}
<style>

      #shopify-section-{{ section.id }} .h2-badge{
       display: flex;           /* 使用flex布局让标识和文字自然对齐 */
            flex-wrap: wrap;          /* 小屏时折行保持可读性 */
            align-items: center;      /* 垂直居中 (标识40px, 文字行高较高时依然对齐) */
            justify-content: center;
      }
      #shopify-section-{{ section.id }}  .new-badge {
            display: inline-flex;           /* 保持与文字在一行 */
            align-items: center;
            justify-content: center;
            width: 46px;
            height: 25px;
            background-color: #3250C3;     /* 鲜明蓝色 */
            color: white;                   /* 白色字 */
            font-size: 14px;               /* 相对h2小一点，但清晰可见 */
            font-weight: 500;
            text-transform: uppercase;       /* new 全大写或小写？ 一般标识大写简洁, 也可小写, 随意 */
            letter-spacing: 0.3px;
            border-radius: 8px;              /* 微微圆角，现代感 (不改变宽高) 如果希望绝对的直角可去掉 */
            /* 保证宽高严格40x40，不受文字内容影响 */
            flex-shrink: 0;
            /* 可选微调位置: 让标识视觉上像是文字的最后部分，与最后一个字贴近 */
            margin-left: 10px;                 /* 几乎紧贴, 但避免黏连 */
            transform: translateY(0);          /* 确保无偏移 */
            line-height: 1;                    /* 防止行高干扰垂直 */
                     
            align-self: center;                /* 强制自身垂直居中 */
            
            vertical-align: middle;             /* 辅助对齐 */
        }

        @media (max-width: 767.98px) {
              #shopify-section-{{ section.id }}  .new-badge {
                width: 34px;
                height: 19px;
                font-size: 12px;      /* 字稍微小一点，保持视觉舒适 */
                border-radius: 5px;       /* 微调圆角比例 */
                margin-left: 6px;          /* 间隙不变，可自行调节 */
                }



                
    
 
  
 
  
  /* 渐变遮罩层 - 上半部分从深到浅渐变，下半部分透明 */
  #shopify-section-{{ section.id }} .image-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%; /* 只覆盖上半部分 */
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.7) 0%,      /* 顶部深色 */
      rgba(0, 0, 0, 0.3) 50%,     /* 中间过渡 */
      rgba(0, 0, 0, 0) 100%       /* 底部完全透明（到达50%高度时已透明） */
    );
    pointer-events: none; /* 让遮罩不干扰点击 */
    z-index: 1;
  }
  
  /* 确保内容在遮罩之上（如果需要文字在遮罩上方显示） */
  #shopify-section-{{ section.id }} .content-wrapper {
    position: relative;
    z-index: 2;
  }
        }

</style>
<div class="section scene-section" >
  <div class="page-width fullscreen-grid-section">
    <div class="section__wrapper grid-container product-box">
          {% for block in section.blocks %}
            <div class="grid-item block-{{ forloop.index }}">
              <div class="image-container">
               {% if block.settings.image != blank %}
                  {%- liquid
                    assign image = block.settings.image
                    assign mobile_image = block.settings.mobile_image | default: image
                    assign image_width = image.width | at_most: 3840
                    assign image_height = image.height | at_most: 3840
                    assign mobile_width = mobile_image.width | at_most: 3840
                    assign mobile_height = mobile_image.height | at_most: 3840
                  -%}
                  
                  <picture>
                    <source
                      media="(max-width: 749px)"
                      srcset="
                        {{ mobile_image | img_url: '800x' }} 800w,
                        {{ mobile_image | img_url: '1600x' }} 1600w
                      "
                      sizes="(max-width: 749px) 100vw"
                      width="{{ mobile_width }}"
                      height="{{ mobile_height }}"
                    >

                    <source
                      media="(min-width: 750px)"
                      srcset="
                        {{ image | img_url: '1200x' }} 1200w,
                        {{ image | img_url: '2400x' }} 2400w
                      "
                      sizes="(min-width: 750px) 100vw"
                      width="{{ image_width }}"
                      height="{{ image_height }}"
                    >

                    <img
                      src="{{ image | img_url: '1200x' }}"
                      alt="{{ block.settings.title | escape }}"
                      class="grid-image"
                      loading="lazy"
                      width="{{ image_width }}"
                      height="{{ image_height }}"
                    >
                  </picture>
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <div class="content-wrapper">
                
                <h2 class="grid-title {% if block.settings.enable_show_new %} h2-badge {% endif %}">{{ block.settings.title }}
                   {% if block.settings.enable_show_new %}
                       <span class="new-badge">NEU</span>
                   {% endif %}

                </h2>
                <h4 class="grid-des">{{ block.settings.description }}</h4>
                <h4 class="grid-usp">{{ block.settings.usp }}</h4>
                
                {% if block.settings.button_link != blank %} 
                  <button
                    type="button"
                    class="btn btn--primary links"
                  >
                    <a href="{{ block.settings.button_link }}" class="grid-button">
                      {{ block.settings.button_title }}
                    </a>
                  </button>
                {% endif %} 
              </div>
            </div>
          {% endfor %}
       
    </div>
  </div>

</div>
{% schema %}
{
  "name": "sections.scene-list",
  "tag": "section",
  "class": "section section-scene-list",
  "max_blocks": 10,
  "disabled_on": {
    "groups": ["footer", "header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "分区标题",
      "default": "我们的特色分区"
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "scene item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "image_pc"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "image_mobile"
        },
        {
          "type": "text",
          "id": "title",
          "label": "大标题"
        },
        {
          "type": "checkbox",
          "id": "enable_show_new",
          "label": "是否显示新品标识",
          "default":false
        }, 
        {
          "type": "text",
          "id": "description",
          "label": "描述"
        },
       {
          "type": "text",
          "id": "usp",
          "label": "卖点"
        },
        {
          "type": "text",
          "id": "button_title",
          "label": "按钮标题"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "按钮链接"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "场景列表",
      "category": "自定义组件",
      "blocks": [
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        }
      ]
    }
  ]
}
{% endschema %}
