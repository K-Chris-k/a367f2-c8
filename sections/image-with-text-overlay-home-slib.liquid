    @media (max-width: 430px){
     #shopify-section-{{ section.id }} .media--extra-large
      {
          height: 650px;  
      }
    
    }

        @media (max-width: 410px){
     #shopify-section-{{ section.id }} .media--extra-large
      {
          height: 620px;  
      }
    
    }

        @media (max-width: 390px){
     #shopify-section-{{ section.id }} .media--extra-large
      {
          height: 600px;  
      }
    
    }

    @media (max-width: 380px){
     #shopify-section-{{ section.id }} .media--extra-large
      {
          height: 550px;  
      }
    }

    /* 轮播样式 */
    #shopify-section-{{ section.id }} .kv-carousel {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .carousel-slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.5s ease-in-out;
    }
    #shopify-section-{{ section.id }} .carousel-slide.active {
      opacity: 1;
      position: relative;
    }
    #shopify-section-{{ section.id }} .carousel-dots {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      z-index: 10;
    }
    #shopify-section-{{ section.id }} .carousel-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background-color: rgba(255, 255, 255, 0.5);
      cursor: pointer;
      transition: all 0.3s ease;
      border: 2px solid transparent;
    }
    #shopify-section-{{ section.id }} .carousel-dot.active {
      background-color: #fff;
      transform: scale(1.2);
      border-color: rgba(255, 255, 255, 0.8);
    }
    #shopify-section-{{ section.id }} .carousel-dot:hover {
      background-color: rgba(255, 255, 255, 0.8);
      transform: scale(1.1);
    }




















/* 进度条指示器样式 - 修复版 */
#shopify-section-{{ section.id }} .carousel-progress {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12px;
  z-index: 10;
  padding: 10px 20px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 30px;
  backdrop-filter: blur(5px);
}

#shopify-section-{{ section.id }} .progress-item {
  width: 60px;
  height: 4px;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 2px;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.3s ease;
}

#shopify-section-{{ section.id }} .progress-item:hover {
  background: rgba(255, 255, 255, 0.5);
  transform: scaleY(1.5);
}

#shopify-section-{{ section.id }} .progress-bar {
  width: 0%;
  height: 100%;
  background: #fff;
  border-radius: 2px;
  transition: width 5s linear;
  /* 添加硬件加速 */
  -webkit-transform: translateZ(0);
  -moz-transform: translateZ(0);
  -ms-transform: translateZ(0);
  -o-transform: translateZ(0);
  transform: translateZ(0);
  /* 确保过渡效果可见 */
  will-change: width;
}

#shopify-section-{{ section.id }} .progress-item.active .progress-bar {
  width: 100%;
}

/* 移动端适配 */
@media (max-width: 767px) {
  #shopify-section-{{ section.id }} .carousel-progress {
    bottom: 20px;
    gap: 8px;
    padding: 8px 16px;
  }
  
  #shopify-section-{{ section.id }} .progress-item {
    width: 40px;
    height: 3px;
  }
}

</style>
<div class="image-with-text-overlay section--padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="{% if section.settings.container == 'full' %}w-full{% else %}page-width{% endif %}">
    <div class="relative overflow-hidden{% unless section.settings.container == 'full' %} blocks-radius{% endunless %}">
      <!-- 轮播容器 -->
      <div class="kv-carousel">
        <!-- 第一张幻灯片：包含图片和文字 -->
        <div class="carousel-slide">
          <parallax-element
            class="block w-full h-full overflow-hidden"
            {% if section.settings.enable_parallax %}
              data-parallax="0.3" data-parallax-direction="{{ section.settings.parallax_direction }}"
            {% endif %}
          >
            <div class="block relative overflow-hidden w-full h-full media mb:media--{{ mobile_height }}{% if desktop_height == 'adapt' %} media--adapt{% else %} media--{{ desktop_height }}{% endif %}">
              {%- if section.settings.image != blank -%}
                {%- capture sizes -%}{% if section.settings.container == 'full' %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
                <picture class="media-wrapper media--height block w-full h-full relative overflow-hidden">
                  {%- if section.settings.image_mobile -%}
                    <source
                      media="(max-width: 767px)"
                      srcset="{{ section.settings.image_mobile | image_url: width: '400x' }} 400w, {{ section.settings.image_mobile | image_url: width: '600x' }} 600w, {{ section.settings.image_mobile | image_url: width: '800x' }} 800w, {{ section.settings.image_mobile | image_url: width: '1000x' }} 1000w"
                      width="{{ section.settings.image_mobile.width }}"
                      height="{{ section.settings.image_mobile.height }}"
                    >
                  {%- endif -%}

                  {{-
                    section.settings.image
                    | image_url: width: section.settings.image.width
                    | image_tag:
                      loading: 'lazy',
                      sizes: sizes,
                      widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200',
                      is: 'image-lazy'
                  -}}
                </picture>
              {%- else -%}
                <div class="media-wrapper">
                  {{- 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' -}}
                </div>
              {%- endif -%}
            </div>
            <!-- 文字内容：只在第一张幻灯片显示 -->
            <div class="image-with-text-overlay__content">
              <div class="image-with-text-overlay__content-wrapper content-overlay section--padding content-overlay--{{ section.settings.content_position }} color-{{ section.settings.color_scheme }}{% if section.settings.container == 'full' %} page-width{% endif %}">
                <div class="relative z-1 rich-text text-{{ section.settings.content_alignment }}" style="max-width: {{ section.settings.max_width }}px;">
                  {%- assign motion_delay = 50 -%}
                  {% for block in section.blocks %}
                    {% case block.type %}
                      {% when 'subheading' %}
                        <motion-element
                          data-motion="fade-up"
                          data-motion-delay="{{ motion_delay }}"
                          class="block rich-text__subheading text-subheading"
                          style="color:#1A1A1A"
                          {{ block.shopify_attributes }}
                        >
                          {{ block.settings.subheading }}
                        </motion-element>
                        {%- assign motion_delay = motion_delay | plus: 50 -%}
                      {% when 'heading' %}
                        <h2 class="pc_show rich-text__heading {{ block.settings.heading_size }}" style="color:{{ section.settings.title_color }}" {{ block.shopify_attributes }} >
                          <motion-element data-motion="fade-up" data-motion-delay="{{ motion_delay }}" class="block">
                            {% render 'highlight-text',
                              text: block.settings.heading,
                              style: block.settings.heading_highlight_style
                            %}
                          </motion-element>
                        </h2>
                        <h2 class="mob_show rich-text__heading {{ block.settings.heading_size }}" style="color:{{ section.settings.title_color }}" {{ block.shopify_attributes }} >
                          <motion-element data-motion="fade-up" data-motion-delay="{{ motion_delay }}" class="block">
                            {% render 'highlight-text',
                              text: 'Fruhlings-Special: Bis zu -57%',
                              style: block.settings.heading_highlight_style
                            %}
                          </motion-element>
                        </h2>
                        {%- assign motion_delay = motion_delay | plus: 50 -%}
                      {% when 'text' %}
                        <motion-element
                          data-motion="fade-up"
                          data-motion-delay="{{ motion_delay }}"
                          class="block rich-text__text rte {{ block.settings.text_size }}"
                          style="color:{{ section.settings.text_color }}"
                          {{ block.shopify_attributes }}
                        >
                          {{- block.settings.text -}}
                        </motion-element>
                        {%- assign motion_delay = motion_delay | plus: 50 -%}
                      {% when 'button' %}
                        <motion-element class="block flex btn-wrapper" data-motion="fade-up" data-motion-delay="{{ motion_delay }}">
                          {% if block.settings.button_label_first != blank %}
                            <a
                              {% if block.settings.button_link_first != blank %}
                                href="{{ block.settings.button_link_first }}"
                              {% else %}
                                role="link" aria-disabled="true"
                              {% endif %}
                              class="btn {{ block.settings.button_style_first }}"
                              {{ block.shopify_attributes }}
                            >
                              {{- block.settings.button_label_first -}}
                            </a>
                          {% endif %}
                          {% if block.settings.button_label_second != blank %}
                             <a
                              {% if block.settings.button_link_second != blank %}
                                href="{{ block.settings.button_link_second }}"
                              {% else %}
                                role="link" aria-disabled="true"
                              {% endif %}
                              class="btn {{ block.settings.button_style_second }}"
                              {{ block.shopify_attributes }}
                            >
                              {{- block.settings.button_label_second -}}
                            </a>
                            {% endif %}
                        </motion-element>
                      {%- assign motion_delay = motion_delay | plus: 50 -%}
                      {% when 'icon_list' %}
                        <div class="icon-list">
                        <motion-element class="block" data-motion="fade-up" data-motion-delay="{{ motion_delay }}">
                          <ul>
                              {% for i in (1..6) %}
                              {% capture img_key %}image{{ i }}{% endcapture %}
                              {% capture title_key %}title{{ i }}{% endcapture %}
                              {% assign image = block.settings[img_key] %}
                              {% assign title = block.settings[title_key] %}
                              {% if image or title %}
                                <li>
                                  {% if image %}
                                    <img src="{{ image | img_url: '120x' }}" alt="{{ title }}">
                                  {% endif %}
                                  {% if title %}
                                    <div class="title">{{ title }}</div>
                                  {% endif %}
                                </li>
                              {% endif %}
                            {% endfor %}
                          </ul>
                        </motion-element>
                        </div>
                      {% when 'countdown' %}
                        {% render 'kv-countdown',block:block %}
                       
                    {% endcase %}
                  {% endfor %}
                </div>
              </div>
            </div>
          </parallax-element>
        </div>
        <!-- 第二张幻灯片：只包含图片 -->
        <div class="carousel-slide">
          <parallax-element
            class="block w-full h-full overflow-hidden"
            {% if section.settings.enable_parallax %}
              data-parallax="0.3" data-parallax-direction="{{ section.settings.parallax_direction }}"
            {% endif %}
          >
            <div class="block relative overflow-hidden w-full h-full media mb:media--{{ mobile_height }}{% if desktop_height == 'adapt' %} media--adapt{% else %} media--{{ desktop_height }}{% endif %}">
              <a href="https://de.indevolt.com/products/indevolt-solidflex-1200-hybrid-balkonkraftwerk-mit-halbfesten-lifepo-akkus?variant=43629440696419">
              <picture class="media-wrapper media--height block w-full h-full relative overflow-hidden">
                {%- if section.settings.image_mobile_slib -%}
                  <source
                    media="(max-width: 767px)"
                    srcset="{{ section.settings.image_mobile_slib | image_url: width: '400x' }} 400w, {{ section.settings.image_mobile_slib | image_url: width: '600x' }} 600w, {{ section.settings.image_mobile_slib | image_url: width: '800x' }} 800w, {{ section.settings.image_mobile_slib | image_url: width: '1000x' }} 1000w"
                    width="{{ section.settings.image_mobile_slib.width }}"
                    height="{{ section.settings.image_mobile_slib.height }}"
                  >
                {%- endif -%}
                <!-- 写死的第二张图片 -->
                  {{-
                    section.settings.image_slib
                    | image_url: width: section.settings.image_slib.width
                    | image_tag:
                      loading: 'lazy',
                      sizes: sizes,
                      widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200',
                      is: 'image-lazy'
                  -}}
              </picture>
              </a>
            </div>
          </parallax-element>
        </div>
        <div class="carousel-progress">
        <div class="progress-item active" data-index="0">
          <div class="progress-bar"></div>
        </div>
        <div class="progress-item" data-index="1">
          <div class="progress-bar"></div>
        </div>
      </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:sections.image-with-text-overlay.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "[Read How-to](https://foxecom.link/fJT8ytn)"
    },
    {
      "type": "header",
