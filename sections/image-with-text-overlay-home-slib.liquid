<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 获取轮播元素
    const carousel = document.querySelector('.kv-carousel');
    const slides = document.querySelectorAll('.kv-carousel .carousel-slide');
    const progressItems = document.querySelectorAll('.progress-item');
    const progressBars = document.querySelectorAll('.progress-bar');
    
    let currentSlide = 0;
    const slideCount = slides.length;
    const slideDuration = 5 * 1000; // 转换为毫秒
    const autoplay = true;
    const pauseOnHover = true;
    
    let intervalId = null;
    let isPaused = false;
    let animationFrame = null;
    
    // 设置初始状态
    function initCarousel() {
      slides[0].classList.add('active');
      progressItems[0].classList.add('active');
      
      // 强制重置所有进度条
      progressBars.forEach(bar => {
        bar.style.transition = 'none';
        bar.style.width = '0%';
      });
      
      // 使用 setTimeout 确保 DOM 更新后再启动动画
      setTimeout(() => {
        if (autoplay && !isPaused) {
          startProgressAnimation(0);
        }
      }, 100);
    }
    
    // 启动进度条动画
    function startProgressAnimation(index) {
      // 先暂停所有动画
      stopProgressAnimation();
      
      // 获取当前活动的进度条
      const activeBar = progressBars[index];
      
      const activeItem = progressItems[index];
      console.log("-------------activeBar");
      console.log(activeBar);
      console.log(activeItem);
      if (!activeBar || !activeItem) return;
      
      // 确保其他进度条宽度为0
      progressBars.forEach((bar, i) => {
        if (i !== index) {
          bar.style.transition = 'none';
          bar.style.width = '0%';
        }
      });
      
      // 使用 requestAnimationFrame 确保过渡效果正确触发
      animationFrame = requestAnimationFrame(() => {
        // 先重置当前进度条
        activeBar.style.transition = 'none';
        activeBar.style.width = '0%';
        
        // 强制浏览器重绘
        activeBar.offsetHeight;
        
        // 在下一次帧中启动动画
        requestAnimationFrame(() => {
          activeBar.style.transition = `width 5s linear`;
          activeBar.style.width = '100%';
          
          // 添加过渡结束事件监听
          const onTransitionEnd = () => {
            activeBar.removeEventListener('transitionend', onTransitionEnd);
            // 如果不是暂停状态，自动切换到下一张
            if (!isPaused && autoplay) {
              nextSlide();
            }
          };
          
          activeBar.addEventListener('transitionend', onTransitionEnd, { once: true });
        });
      });
    }
    
    // 停止进度条动画
    function stopProgressAnimation() {
      if (animationFrame) {
        cancelAnimationFrame(animationFrame);
        animationFrame = null;
      }
      
      progressBars.forEach(bar => {
        bar.style.transition = 'none';
      });
    }
    
    // 切换到指定幻灯片
    function goToSlide(index) {
      // 移除所有活动状态
      slides.forEach(slide => slide.classList.remove('active'));
      progressItems.forEach(item => item.classList.remove('active'));
      
      // 设置新的活动状态
      slides[index].classList.add('active');
      progressItems[index].classList.add('active');
      currentSlide = index;
      
      // 启动新幻灯片的进度条动画
      if (autoplay && !isPaused) {
        startProgressAnimation(index);
      }
    }
    
    // 下一张幻灯片
    function nextSlide() {
      const nextIndex = (currentSlide + 1) % slideCount;
      goToSlide(nextIndex);
    }
    
    // 开始自动轮播
    function startAutoSlide() {
      if (intervalId) {
        clearInterval(intervalId);
      }
      
      // 设置定时器作为后备方案
      intervalId = setInterval(() => {
        if (!isPaused && autoplay) {
          nextSlide();
        }
      }, slideDuration + 100); // 增加100ms避免与 transitionend 冲突
      
      // 启动第一个进度条动画
      if (!isPaused) {
        startProgressAnimation(currentSlide);
      }
    }
    
    // 暂停轮播
    function pauseAutoSlide() {
      if (isPaused) return;
      isPaused = true;
      
      // 暂停当前动画
      stopProgressAnimation();
      
      // 清除定时器
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
      
      // 记录当前进度
      const activeBar = progressBars[currentSlide];
      if (activeBar) {
        const currentWidth = activeBar.style.width;
        activeBar.style.transition = 'none';
        activeBar.style.width = currentWidth;
      }
    }
    
    // 恢复轮播
    function resumeAutoSlide() {
      if (!isPaused) return;
      isPaused = false;
      
      if (autoplay) {
        // 重新启动进度条动画
        const activeBar = progressBars[currentSlide];
        if (activeBar) {
          const currentWidth = parseFloat(activeBar.style.width) || 0;
          const remainingTime = (100 - currentWidth) / 100 * slideDuration;
          
          if (currentWidth < 100) {
            // 继续剩余动画
            activeBar.style.transition = `width ${remainingTime/1000}s linear`;
            activeBar.style.width = '100%';
            
            // 添加过渡结束事件
            const onTransitionEnd = () => {
              activeBar.removeEventListener('transitionend', onTransitionEnd);
              if (!isPaused && autoplay) {
                nextSlide();
              }
            };
            activeBar.addEventListener('transitionend', onTransitionEnd, { once: true });
          }
        }
        
        // 重新启动定时器
        startAutoSlide();
      }
    }
    
    // 点击进度条切换幻灯片
    progressItems.forEach((item, index) => {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        
        // 暂停当前轮播
        pauseAutoSlide();
        
        // 切换到点击的幻灯片
        goToSlide(index);
        
        // 短暂延迟后恢复轮播
        setTimeout(() => {
          resumeAutoSlide();
        }, 100);
      });
    });
    
    // 鼠标悬停暂停功能
    if (pauseOnHover) {
      carousel.addEventListener('mouseenter', pauseAutoSlide);
      carousel.addEventListener('mouseleave', resumeAutoSlide);
    }
    
    // 初始化轮播
    initCarousel();
    
    // 启动自动轮播
    if (autoplay) {
      startAutoSlide();
    }
    
    // 页面可见性变化时处理
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        pauseAutoSlide();
      } else {
        resumeAutoSlide();
      }
    });
    
    // 处理窗口大小变化
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        // 窗口大小变化后，重新调整进度条状态
        if (!isPaused) {
          stopProgressAnimation();
          startProgressAnimation(currentSlide);
        }
      }, 250);
    });
  });
</script>