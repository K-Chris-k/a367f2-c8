{%- liquid
  assign motion_delay = 50
  assign slides = section.blocks | where: 'type', 'slide'
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed
-%}
<style>
  #shopify-section-{{ section.id }}{padding-top:{{section.settings.padding_top  }}px;padding-bottom:{{section.settings.padding_bottom  }}px;}
  #shopify-section-{{ section.id }} h2{ line-height:58px;font-size:46px;font-weight: 700;text-align:center}
  #shopify-section-{{ section.id }} h2 .links{ display: block;margin-top: 20px;line-height: 19px; font-size: 16px;  font-weight: normal;color: #3250C3; }
  #shopify-section-{{ section.id }} .triple-slider-section { width: 100%;  max-width: 100%;  margin: 0 auto;}
  #shopify-section-{{ section.id }} .triple-slider-container {
     position: relative;
     margin-top:40px;
     overflow:hidden;
     /* 为箭头提供足够的左右空间，使其位于图片外部 */
     padding: 0 40px;
  }

 
 
 #shopify-section-{{ section.id }} .image-wrapper {
  position: relative;
  width: 1200px;
  height: 600px;
  overflow: hidden;
  border-radius: 8px 8px 0 0; /* 可选：添加顶部圆角 */
}

 #shopify-section-{{ section.id }} .image-wrapper .slide-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  #shopify-section-{{ section.id }} .slick-track {
      display: flex;
      gap: 16px;
  }

#shopify-section-{{ section.id }} .content {
  position: relative;  /* 改为相对定位 */
  bottom: 0;           /* 移除bottom定位 */
  padding: 20px 0px 0px 0px;  /* 增加上下内边距 */
  color: #333;         /* 改为深色文字，因为背景不再是图片 */
  background: #fff;    /* 添加背景色 */
  text-shadow: none;   /* 移除文字阴影 */
  border-radius: 0 0 8px 8px; /* 可选：添加底部圆角 */
  {% comment %} box-shadow: 0 2px 8px rgba(0,0,0,0.1); /* 可选：添加阴影增加层次感 */ {% endcomment %}
}

#shopify-section-{{ section.id }} .content h2 {
  line-height: 28px;
  font-size: 20px;
  text-align: left;
  color: #333;  /* 改为深色 */
}

#shopify-section-{{ section.id }} .content .describe {
  margin-top: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 8;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width:900px;
  min-height:38px;
}

#shopify-section-{{ section.id }} .content .describe p {
  line-height: 19px;
  font-size: 16px;
  margin: 0px;
  color: #666;  /* 添加描述文字颜色 */
}


  
  /* PC端箭头样式 - 定位在图片外部右下角区域 */
  #shopify-section-{{ section.id }} .carousel-arrows {
    position: relative;
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 16px;
    margin-bottom: 0;
    /* 与图片区域右对齐，位于图片外部下方 */
    {% comment %} padding-left: 1000px; {% endcomment %}
    transform: translateY(0%);
  }

 
  
  #shopify-section-{{ section.id }} .carousel-arrows button {
    position: relative;
    background:#3250C3;
    border: 1px solid rgba(255, 255, 255, 0.3);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    padding: 0;
    font-size: 0;
    cursor: pointer;
    color: #fff;
    transition: all 0.3s ease;
    pointer-events: all;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: none;
    backdrop-filter: blur(4px);
  }
  
  #shopify-section-{{ section.id }} .carousel-arrows button:hover {
    background: #3D60E4;
    border-color: rgba(255, 255, 255, 0.6);
    transform: scale(1.05);
  }
  
  /* 自定义箭头图标 (使用伪元素实现箭头形状) */
  #shopify-section-{{ section.id }} .carousel-arrows button.prev-arrow::before,
  #shopify-section-{{ section.id }} .carousel-arrows button.next-arrow::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
  }
  
  #shopify-section-{{ section.id }} .carousel-arrows button.prev-arrow::before {
    transform: translate(-50%, -50%) rotate(45deg);
    margin-left: 2px;
  }
  
  #shopify-section-{{ section.id }} .carousel-arrows button.next-arrow::before {
    transform: translate(-50%, -50%) rotate(-135deg);
    margin-left: -2px;
  }
  
  /* 隐藏slick默认箭头，使用自定义箭头 */
  #shopify-section-{{ section.id }} .slick-prev,
  #shopify-section-{{ section.id }} .slick-next {
    display: none !important;
  }

  /* 移动端样式 */
  @media (max-width: 820px) {

    #shopify-section-{{ section.id }}{padding-top:{{section.settings.padding_top | divided_by: 2  }}px;padding-bottom:{{section.settings.padding_bottom | divided_by: 2  }}px;}
    #shopify-section-{{ section.id }} h2{ line-height:34px;font-size:28px;text-align:left;padding: 0 15px;}
    #shopify-section-{{ section.id }} h2 .links{ margin-top: 10px;}
    #shopify-section-{{ section.id }} .triple-slider-container { 
      margin-top:30px;
      padding: 0 15px;
      overflow: visible; /* 确保内容完整显示 */
    }
      
    #shopify-section-{{ section.id }} .triple-carousel .slick-track {
      gap: 0; /* 移动端移除滑块间距 */
    }

      #shopify-section-{{ section.id }} .triple-carousel .slide {
      min-width: auto; /* 移除最小宽度限制 */
      width: 100%; /* 占满整个宽度 */
      padding: 0; /* 移除内边距 */
    }

   #shopify-section-{{ section.id }} .image-wrapper {
    width: 100%;
    max-width: 100%;
    min-width: auto;
    max-height:280px;
  }

      
  #shopify-section-{{ section.id }} .content {
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
  }


    /* 确保滑块容器宽度正确 */
  #shopify-section-{{ section.id }} .triple-carousel {
    width: 100%;
  }
  
  #shopify-section-{{ section.id }} .slick-list {
    overflow: hidden;
  }


    #shopify-section-{{ section.id }} .content h2{line-height: 17px;font-size: 14px;padding: 0 0px;}
    #shopify-section-{{ section.id }} .content .describe {
      max-width:300px;
      min-height:105px;
    }
    #shopify-section-{{ section.id }} .content .describe p{line-height:17px;font-size: 14px;}
    #shopify-section-{{ section.id }} .carousel-arrows {
          position: relative;
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 0px;
    margin-bottom: 0;
    /* 与图片区域右对齐，位于图片外部下方 */
    padding-left: 10px;
    transform: translateY(0%);
    }


 
    #shopify-section-{{ section.id }} .slide-content {
      padding: 15px;
    }
    #shopify-section-{{ section.id }} .slide-heading {
      font-size: 1rem;
    }




      #shopify-section-{{ section.id }} .carousel-arrows button {
    
    width: 32px;
    height: 32px;
   
  }
  }
</style>

<div class="triple-slider-section" data-section-id="{{ section.id }}">
  {% if section.settings.title != blank %}
    <h2>
      <motion-element class="block" data-motion="fade-up" data-motion-delay="{{ motion_delay }}">
        <span>{{ section.settings.title }}</span>
         {% if section.settings.more_title != blank and section.settings.more_url != blank%}
            <span class="links"><a href="{{ section.settings.more_url }}" target="_blank">{{ section.settings.more_title }}</a></span>
        {% endif %}
      </motion-element>
      
    </h2>
  {% endif %}
  <div class="triple-slider-container">
    <div class="triple-carousel">
      {% for block in slides %}
<div class="slide" {{ block.shopify_attributes }}>
  {% if block.settings.image_pc != blank %}
    <!-- 图片链接部分 -->
      <div class="image-wrapper">
        <picture>
          <source
            media="(max-width: 749px)"
            srcset="
              {{ block.settings.image_mobile | img_url: '800x' }} 1x,
              {{ block.settings.image_mobile | img_url: '1600x' }} 2x
            "
          >
          <source
            media="(min-width: 750px)"
            srcset="
              {{ block.settings.image_pc | img_url: '1200x' }} 1x,
              {{ block.settings.image_pc | img_url: '2400x' }} 2x
            "
          >
          <img
            src="{{ block.settings.image_pc | img_url: '1200x' }}"
            alt="{{ block.settings.title | escape }}"
            class="slide-image"
            loading="lazy"
            width="{{ block.settings.image_pc.width }}"
            height="{{ block.settings.image_pc.height }}"
          >
        </picture>
      </div>
    
    <!-- 内容区域移到图片外部 -->
    {% if block.settings.title != blank %}  
        <div class="content">
          {% if block.settings.author %}
            <div class="author">{{ block.settings.author }}</div>
          {% endif %}
          <h2 class="title">{{ block.settings.title }}</h2>
          <div class="describe">{{ block.settings.describe }}</div>
          {% if block.settings.date %}
            <div class="date">{{ block.settings.date }}</div>
          {% endif %}
        </div>
    {% endif %}
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
  {% endif %}
</div>
      {% endfor %}
    </div>
    <div class="carousel-arrows page-width">
      <button class="prev-arrow" aria-label="Previous slide">❮</button>
      <button class="next-arrow" aria-label="Next slide">❯</button>
    </div>
  </div>
</div>

<script>
    $(document).ready(function () {
      let $slider = $('[data-section-id="{{ section.id }}"] .triple-carousel');
      $slider.slick({
        slidesToShow: {% if section.blocks.size > 3 %}3{% else %}2{% endif %},
        slidesToScroll: 1,
        centerMode:  {% if section.blocks.size > 3 %}true{% else %}true{% endif %},
        centerPadding: {% if section.blocks.size > 3 %}'0'{% else %}'10%'{% endif %},
        variableWidth: {% if section.blocks.size > 3 %}true{% else %}true{% endif %},
        arrows: true,
        dots: false,
        infinite: true,
        draggable:true,
        speed: 300,
        autoplay: {{ autoplay }},
        autoplaySpeed: {{ autoplay_speed }},
        prevArrow: $('[data-section-id="{{ section.id }}"] .prev-arrow'),
        nextArrow: $('[data-section-id="{{ section.id }}"] .next-arrow'),
        responsive: [
          {
            breakpoint: 1024,
            settings: {
              slidesToShow: 2
            }
          },
          {
            breakpoint: 768,
            settings: {
              slidesToShow: 1,        // 移动端只显示1个
              slidesToScroll: 1,
              centerMode: false,      // 关闭居中模式
              variableWidth: false,   // 关闭可变宽度
              arrows: false,          // 隐藏箭头（可选）
              dots: false
            }
          }
        ]
      });
    });
</script>

{% schema %}
{
  "name": "Fullscreen Slider",
  "max_blocks": 6,
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Title"
    },
    {
      "type": "text",
      "id": "more_title",
      "label": "更多",
    },
    {
      "type": "url",
      "id": "more_url",
      "label": "链接",
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay Speed",
      "default": 3000
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
         {
          "type": "url",
          "id": "links",
          "label": "link"
        },
        {
          "type": "image_picker",
          "id": "image_pc",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image"
        },
         {
          "type": "text",
          "id": "author",
          "label": "author"
        },
        {
          "type": "text",
          "id": "title",
          "label": "title"
        },
        {
          "type": "richtext",
          "id": "describe",
          "label": "describe"
        },
        {
          "type": "text",
          "id": "date",
          "label": "date"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "全屏滑块+文本",
      "category": "自定义产品组件",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}