<script>
     (function() {
        // 存储动画状态，避免重复动画干扰
        let animatingItems = new Set();
        
        // 获取所有进度条项目
        const progressItems = document.querySelectorAll('.progress-item');
        
        // 动画函数：将进度条从当前值平滑过渡到目标值
        function animateProgressBar(item, targetPercent, duration = 1200) {
            return new Promise((resolve) => {
                // 防止同一个进度条同时进行多个动画
                if (animatingItems.has(item)) {
                    // 如果已经在动画中，先停止当前动画
                    const fillDiv = item.querySelector('.progress-fill');
                    const currentWidth = parseFloat(fillDiv.style.width) || 0;
                    fillDiv.style.transition = 'none';
                    fillDiv.style.width = currentWidth + '%';
                    void fillDiv.offsetHeight;
                    fillDiv.style.transition = '';
                    animatingItems.delete(item);
                }
                
                animatingItems.add(item);
                
                const fillDiv = item.querySelector('.progress-fill');
                const valueSpan = item.querySelector('.progress-value .progress-value-money');
                const mobileBadge = item.querySelector('.mobile-value-badge .progress-mobile-value-money');
                
                // 获取当前宽度值
                let startWidth = 0;
                const currentStyle = fillDiv.style.width;
                if (currentStyle && currentStyle !== '') {
                    const match = currentStyle.match(/(\d+(?:\.\d+)?)%/);
                    if (match) {
                        startWidth = parseFloat(match[1]);
                    }
                }
                
                // 如果起始值和目标值相同，直接更新数字并返回
                if (Math.abs(startWidth - targetPercent) < 0.1) {
                    const displayVal = Math.round(targetPercent) + '€';
                    if (valueSpan) valueSpan.innerText = displayVal;
                    if (mobileBadge) mobileBadge.innerText = displayVal;
                    animatingItems.delete(item);
                    resolve();
                    return;
                }
                
                // 更新数字的动画
                const startValue = startWidth;
                const endValue = targetPercent;
                const startTime = performance.now();
                
                function updateNumbers(currentPercent) {
                    const roundedVal = Math.round(currentPercent*10);
                    const displayVal = roundedVal + '€';
                    if (valueSpan && valueSpan.innerText !== displayVal) {
                        valueSpan.innerText = displayVal;
                    }
                    if (mobileBadge && mobileBadge.innerText !== displayVal) {
                        mobileBadge.innerText = displayVal;
                    }
                }
                
                updateNumbers(startWidth);
                
                fillDiv.style.transition = `width ${duration}ms cubic-bezier(0.25, 0.46, 0.45, 0.94)`;
                fillDiv.style.width = targetPercent + '%';
                
                let animationFrameId = null;
                
                function animateNumbers(now) {
                    const elapsed = now - startTime;
                    let progress = Math.min(1, elapsed / duration);
                    const easeOutCubic = 1 - Math.pow(1 - progress, 3);
                    const currentPercent = startValue + (endValue - startValue) * easeOutCubic;
                    updateNumbers(currentPercent);
                    
                    if (progress < 1) {
                        animationFrameId = requestAnimationFrame(animateNumbers);
                    } else {
                        updateNumbers(endValue);
                        if (animationFrameId) cancelAnimationFrame(animationFrameId);
                    }
                }
                
                animationFrameId = requestAnimationFrame(animateNumbers);
                
                const onTransitionEnd = () => {
                    fillDiv.removeEventListener('transitionend', onTransitionEnd);
                    if (animationFrameId) cancelAnimationFrame(animationFrameId);
                    updateNumbers(targetPercent);
                    animatingItems.delete(item);
                    resolve();
                };
                
                fillDiv.addEventListener('transitionend', onTransitionEnd, { once: true });
                
                setTimeout(() => {
                    if (animatingItems.has(item)) {
                        fillDiv.removeEventListener('transitionend', onTransitionEnd);
                        if (animationFrameId) cancelAnimationFrame(animationFrameId);
                        updateNumbers(targetPercent);
                        animatingItems.delete(item);
                        resolve();
                    }
                }, duration + 100);
            });
        }
        
        // 设置进度条到指定值（无动画）
        function setProgressInstant(item, percent) {
            const fillDiv = item.querySelector('.progress-fill');
            const valueSpan = item.querySelector('.progress-value .progress-value-money');
            const mobileBadge = item.querySelector('.mobile-value-badge .progress-mobile-value-money');
            const displayVal = Math.round(percent) + '€';
            
            fillDiv.style.transition = 'none';
            fillDiv.style.width = percent + '%';
            if (valueSpan) valueSpan.innerText = displayVal;
            if (mobileBadge) mobileBadge.innerText = displayVal;
            
            void fillDiv.offsetHeight;
            fillDiv.style.transition = '';
            
            item.setAttribute('data-current-progress', percent);
        }
        
        // 播放所有进度条动画到目标值
        function playAllAnimations() {
            const items = document.querySelectorAll('.progress-item');
            const promises = [];
            items.forEach(item => {
                const targetProgress = parseFloat(item.getAttribute('data-target-progress')) || 0;
                promises.push(animateProgressBar(item, targetProgress, 1200).then(() => {
                    item.setAttribute('data-current-progress', targetProgress);
                }));
            });
            return Promise.all(promises);
        }
        
        // 重置所有进度条为0
        function resetAllProgress() {
            const items = document.querySelectorAll('.progress-item');
            items.forEach(item => {
                if (animatingItems.has(item)) {
                    const fillDiv = item.querySelector('.progress-fill');
                    fillDiv.style.transition = 'none';
                    animatingItems.delete(item);
                }
                setProgressInstant(item, 0);
                item.setAttribute('data-current-progress', 0);
            });
        }
        
        // 随机更新进度条数值并带动画
        function randomUpdate() {
            const items = document.querySelectorAll('.progress-item');
            items.forEach(item => {
                const newValue = Math.floor(Math.random() * 101);
                item.setAttribute('data-target-progress', newValue);
                animateProgressBar(item, newValue, 1000).then(() => {
                    item.setAttribute('data-current-progress', newValue);
                });
            });
        }
        
        // 暴露全局方法
        window.updateShopifyProgress = function(identifier, newPercent) {
            let targetItem = null;
            const items = document.querySelectorAll('.progress-item');
            
            if (typeof identifier === 'number') {
                if (items[identifier]) {
                    targetItem = items[identifier];
                }
            } else if (typeof identifier === 'string') {
                for (let i = 0; i < items.length; i++) {
                    const labelSpan = items[i].querySelector('.progress-label');
                    if (labelSpan && labelSpan.innerText.includes(identifier)) {
                        targetItem = items[i];
                        break;
                    }
                }
            }
            
            if (targetItem) {
                let percent = Math.min(100, Math.max(0, parseFloat(newPercent)));
                if (isNaN(percent)) percent = 0;
                targetItem.setAttribute('data-target-progress', percent);
                animateProgressBar(targetItem, percent, 1000).then(() => {
                    targetItem.setAttribute('data-current-progress', percent);
                });
                return true;
            }
            console.warn('updateShopifyProgress: 未找到指定进度条');
            return false;
        };
        
        // 每次滚动到可视区域都播放动画
        function initScrollAnimation() {
            const section = document.querySelector('.progress-section');
            if (!section) return;
            
            let isAnimating = false;
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting && !isAnimating) {
                        isAnimating = true;
                        
                        // 重置所有进度条
                        resetAllProgress();
                        
                        // 播放动画
                        setTimeout(() => {
                            playAllAnimations().then(() => {
                                // 动画完成后重置标志
                                setTimeout(() => {
                                    isAnimating = false;
                                }, 200);
                            }).catch(() => {
                                isAnimating = false;
                            });
                        }, 50);
                    }
                });
            }, { 
                threshold: 0.2  // 当元素20%进入视口时触发
            });
            
            observer.observe(section);
        }
        
        // 初始化进度条
        function initProgressBars() {
            const items = document.querySelectorAll('.progress-item');
            items.forEach(item => {
                const targetVal = parseFloat(item.getAttribute('data-target-progress')) || 0;
                item.setAttribute('data-target-progress', targetVal);
                item.setAttribute('data-current-progress', 0);
                const fillDiv = item.querySelector('.progress-fill');
                const valueSpan = item.querySelector('.progress-value .progress-value-money');
                const mobileBadge = item.querySelector('.mobile-value-badge .progress-mobile-value-money');
                if (fillDiv) {
                    fillDiv.style.width = '0%';
                    fillDiv.style.transition = '';
                }
                if (valueSpan) valueSpan.innerText = '0€';
                if (mobileBadge) mobileBadge.innerText = '0€';
            });
        }
        
        // 页面完全加载后初始化
        window.addEventListener('load', () => {
            initProgressBars();
            initScrollAnimation();
        });
        
        // 暴露重新播放动画的方法
        window.replayProgressAnimation = function() {
            resetAllProgress();
            setTimeout(() => {
                playAllAnimations();
            }, 50);
        };
    })();
</script>
