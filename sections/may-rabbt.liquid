  #shopify-section-{{ section.id }} .title{ font-size: 48px;font-weight: 700;text-align:center;color:#000}
  #shopify-section-{{ section.id }} {
    margin-top: {{ section.settings.padding_top }}px;
    margin-bottom: {{ section.settings.padding_bottom }}px;
  }

    #shopify-section-{{ section.id }} .page-width {
    flex-flow: column;
    padding-top: {{ section.settings.padding_top_inner }}px;
    padding-bottom: {{ section.settings.padding_bottom_inner }}px;
  }


 .scene-section .fullscreen-grid-section {
    width: 100%;
    padding:1rem;
    overflow: hidden;
  }
  .grid-container {
    display: grid;
    width: 100%;
    grid-template-columns: 61% 1fr;
    grid-template-rows: 1fr;
    gap: 1rem;
  }
  .grid-item {
    position: relative;
    border-radius:20px;
    height: 298px;
    overflow: hidden;
  }
  .grid-item:hover .grid-image {
    /*transform: scale(1.05);*/
  }

  @media screen and (min-width: 769px) {
    #shopify-section-{{ section.id }} .grid-item:nth-child(3) {
      grid-column: 1 / span 2;
    }
  }

  .image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    min-height: 100%;
    min-width: 100%;
  }
  .grid-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.3s ease;
  }
  .placeholder-image {
    width: 100%;
    height: 100%;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    svg {
      width: 100%;
      height: 100%;
    }
  }
  .content-wrapper {
    position: absolute;
    width:100%;
    top: 30%;
    left: 50%;
    padding:0px 60px;
    transform: translate(-50%, 0%);
    display: flex;
    flex-flow: column;
    text-align: center;
    align-items: center;  /* 让表单内部元素也居中 */
    z-index: 2;
  }
  .content-wrapper h2,.content-wrapper h4{
    line-height: 22px;
    color:#fff
  }

  .flex-container {
    display: flex;
    justify-content: left;
    gap: 10px;
  }

   .copy-button{
    background: #DC222C;
    color: #ffffff;
    {% comment %} border: 2px solid #DC222C; {% endcomment %}
  }      

  .copy-button:hover{
    background-color: #DC222C!important;
    color: #ffffff;
    color-border:#DC222C!important;
    {% comment %} border: 2px solid #DC222C; {% endcomment %}
  }    
 
  .rabatt p{color: #1A1A1A!important;text-align: left;max-width:1380px;line-height: 17px;font-size: 14px;}
  .content-wrapper .grid-title{line-height: 34px;font-size: 28px;font-family: 'Inter';font-weight: 700;color:#1A1A1A!important;}
  .content-wrapper .grid-des{margin-top:6px;line-height: 24px;font-size: 20px;font-family: 'Inter';font-weight: 500;color:#1A1A1A!important;}
  .content-wrapper .grid-des strong{font-weight: 700;display:block;}
  .content-wrapper .links{margin-top:20px;padding:10px 20px;max-width: 178px;}
  .content-wrapper .links:hover,.content-wrapper .links:focus{border-color:#DC222C!important}


  #shopify-section-{{ section.id }} .icon-gift{ width: 4rem; height: 4.5rem;margin: 0px 10px;}



  
      #shopify-section-{{ section.id }} .title-container {
      display: flex;
      align-items: center!important;  /* 关键：垂直居中 */
      gap: 0px;  /* 控制间距 */
}

#shopify-section-{{ section.id }} .icon-gift {
  flex-shrink: 0;  /* 防止SVG被压缩 */
  color: #333;
}

#shopify-section-{{ section.id }} h2 {
  margin: 0;  /* 移除默认边距 */
  flex: 1;  /* 让h2占据剩余空间 */
}

 

