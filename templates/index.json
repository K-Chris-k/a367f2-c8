    "review_list_XNNiXX": {
      "type": "review-list",
      "blocks": {
        "card_33CQFy": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/review-12-pc.jpg",
            "image_mobile": "shopify://shop_images/review-12-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Geniales Balkonkraftwerk mit toller SoftwareHabe bereits die 2. in Vollkonfiguration bestellt weil das Teil echt was kann. Ideal für Dynamische Tarife und Balkonkraft PV. Auch Clustern bis 30kwh möglich. Bei dem Preis echt unschlagbar. Klare Empfehlung",
            "name": "Wilhelm Bauer"
          }
        },
        "card_WfXWQr": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/review-11-pc.jpg",
            "image_mobile": "shopify://shop_images/review-11-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Nach langer Suche nach einem geeigneten PV Akku bin ich über die SF2000 gestolpert. Die flexiblen Erweiterungs- und Anschlußmöglichkeiten, technischen Daten und vor allem die Möglichkeit der lokalen Steuerung auch ohne Cloud haben mich überzeugt. Der Speicher ist noch nicht so bekannt, aber ich würde ihn sofort wieder kaufen. Support und Feedback bei Fragen ist Top",
            "name": "Rainer"
          }
        },
        "card_gD7KCd": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review1-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review1-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Ich habe den SolidFlex 2000+SFA1800 mit 4 Modulen und SMD3. Funktioniert erstaunlich gut. Akkuladung, Einspeisung nur für Eigenverbrauch. Bin super zufrieden.",
            "name": "Christian H."
          }
        },
        "card_Hrg3dX": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review2-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review2-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Material sehr hochwertig und schwer, Einrichtung Shelly/Ecotracker/Gerät selber sehr gut und einfach, das Netzkabel ist sehr massiv.",
            "name": "Fettarme Hmilch"
          }
        },
        "card_jq89aU": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/home-Kunden-img1.jpg",
            "image_mobile": "shopify://shop_images/home-Kunden-img1.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Der Indevolt SolidFlex 2000 Speicher für Balkonkraftwerke oder kleine PV-Anlagen punktet durch einfache Plug-and-Playinstallation und unterbrechungsfreier Notstromversorgung. Außerdem lässt er sich auf bis zu 10,8 kWh erweitern und sogar ins Smart Home einbinden.",
            "name": "Mariella W."
          }
        },
        "card_edrE37": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/image00002.jpg",
            "image_mobile": "shopify://shop_images/image00002.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Anhand eurer anstrenung habe ich vom meinem stromanbieter 340 euroerhalten ich muss euch wirklich danken und ihr seit ein super team",
            "name": "Bernhard Fasser"
          }
        },
        "card_YH9LNL": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review3-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review3-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Mit einer Kapazität von 1600Wh deckt es super gut unseren Strombedarf nachts. Ich kann es echt empfehlen!",
            "name": "Hans Müller"
          }
        },
        "card_Pq9FhP": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review4-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review4-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Leicht und perfekt für den Campinggebrauch. Die 1600Wh Kapazität sind klasse! Ich kann mehrere Geräte gleichzeitig nutzen.",
            "name": "Michail Cohen"
          }
        },
        "card_38DYVV": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review5-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review5-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Morgenenergie. Die heutige Wahl: Indevolt BK1600 – ein wahrer Erbe jeder Sonnenstrahlung.",
            "name": "Leon Fischer"
          }
        },
        "card_my4qMB": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review7-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review7-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Die Indevolt-Lösung gibt mir wirklich Ruhe: Das System erkennt Stromausfälle in weniger als 10 ms und schützt meine Familienfotos sofort auf meinem PC oder NAS. Absolute Empfehlung für jede Familie, die ihre Erinnerungen sichern will!",
            "name": "Lukas Müller"
          }
        },
        "card_bCBJDy": {
          "type": "card",
          "settings": {
            "image_pc": "shopify://shop_images/index-review8-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review8-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Im Off-Grid-Modus versorgt der BK1600 Ultra Haushaltslasten zuverlässig mit Strom, sodass Waschmaschine und andere Geräte auch ohne externe Energiequelle weiterlaufen können.",
            "name": "Martin Braun"
          }
        },
        "card_R8PxWw": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image_pc": "shopify://shop_images/index-review9-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review9-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Durch die Verwendung des BK1600 Ultra + BK1600 lässt sich die 800W Grenze durchbrechen und ihr könnt beide Speicher mit 1200W laden sofern die Solarmodule das hergeben. Zeitgleich könnt ihr eure gewonnene Energie speichern und diese Nachts nutzen! Je nach eurem Grundbedarf zb. kleiner als 200W könntet ihr mit 2 Speicher die komplette Nacht abdecken.",
            "name": "Daniel Reichmann"
          }
        },
        "card_3YjKzT": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image_pc": "shopify://shop_images/index-review10-pc.jpg",
            "image_mobile": "shopify://shop_images/index-review10-pc.jpg",
            "start": "shopify://shop_images/start.svg",
            "content": "Der BK1600 macht grundsätzlich was er soll. Das Gerät wird weiterhin verbessert und bietet von Haus aus die Möglichkeiten die beworben werden. Zudem werden die verfügbaren Kapazitäten durch ein sinnvolles Entlademanagement nach bester Möglichkeit erhöht. Ich bin jedenfalls weiterhin sehr begeistert.",
            "name": "Alex Miriel"
          }
        }
      },
