    "custom_liquid_dJyEHh": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n    /* 全局重置 & 基础样式 */\n/*     * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      background-color: #000000;\n      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;\n      line-height: 1.5;\n    } */\n\n    /* 外部黑色背景 + 居中对齐容器 (与原设计一致) */\n    .outer-container {\n      background-color: #000000;\n      padding: 15px;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      min-height: 80vh;\n    }\n\n    /* 书页风格主容器: 左右两栏 (像书本摊开) */\n    .outer-container .book-layout {\n      max-width: 1280px;\n      width: 100%;\n      background-color: #000000;   /* 黑色底色，左右区块内部为深灰/黑底，但文本统一灰色 */\n      display: flex;\n      flex-wrap: wrap;            /* 移动端折行，保持书本风格 */\n      gap: 2rem;\n      /* 内边距模拟页面留白 (响应式继承haft-div的padding感) */\n      padding: 0px 20px;\n    }\n\n    /* 左右两个页面 (column) */\n    .outer-container .page-col {\n      flex: 1;\n      min-width: 260px;\n      background: transparent;\n      /* 类似书页的轻微分隔效果: 可选右边框线 (只在桌面版右栏左侧加分隔) */\n    }\n\n    /* 左侧栏: 主要包含前半部分文案 */\n    .outer-container .left-page {\n      /* 没有任何额外背景，保持纯粹 */\n    }\n\n    /* 右侧栏: 包含原本后半计算细节 */\n    .outer-container .right-page {\n      /* 可以增加淡淡的左侧装饰线，模拟书缝 */\n      /* border-left: 1px solid rgba(138, 138, 138, 0.25); */\n      padding-left: 1.5rem;\n    }\n\n    /* 公用文本样式，保持原有的灰色风格 */\n    .outer-container .page-col h3 {\n      color: #8A8A8A;\n      font-size: 20px;\n      margin-bottom: 1.25rem;\n      font-weight: 600;\n      letter-spacing: -0.01em;\n    }\n\n    .outer-container .page-col p, \n    .outer-container .page-col div[data-line=\"true\"] {\n      color: #8A8A8A;\n      font-size: 14px;\n      margin-bottom: 0.75rem;\n    }\n\n    /* 针对直接span或内联块保持统一 */\n    .outer-container .text-block {\n      color: #8A8A8A;\n      font-size: 14px;\n      margin-bottom: 0.75rem;\n      line-height: 1.5;\n    }\n\n    .outer-container .text-block b, .outer-container strong {\n      color: #8A8A8A;\n      font-weight: 600;\n    }\n\n    /* 链接样式 */\n    .outer-container a {\n      color: #8A8A8A;\n      text-decoration: underline;\n      text-decoration-thickness: 1px;\n      text-underline-offset: 2px;\n      transition: opacity 0.2s;\n    }\n\n    .outer-container a:hover {\n      opacity: 0.7;\n      color: #c0c0c0;\n    }\n\n    /* 公式 / 计算细节段落可以保留等宽风格 */\n    .outer-container .calc-detail {\n      font-family: 'SF Mono', 'Menlo', monospace;\n      font-size: 0.9rem;\n      background: rgba(255,255,255,0.03);\n      padding: 0.2rem 0.4rem;\n      border-radius: 6px;\n      display: inline-block;\n    }\n\n    .outer-container hr {\n      border: none;\n      border-top: 1px solid rgba(138, 138, 138, 0.2);\n      margin: 1rem 0;\n    }\n\n    /* 保持原来的空行br样式 */\n    .outer-container .spacer {\n      height: 0.75rem;\n    }\n\n    /* 移动端适配: 书本变为上下堆叠，右侧边框消失 */\n    @media (max-width: 768px) {\n      .outer-container .book-layout {\n        flex-direction: column;\n        padding: 50px 20px;\n        gap: 0rem;\n      }\n      .outer-container .right-page {\n        border-left: none;\n        padding-left: 0;\n        margin-top: 0.5rem;\n      }\n      .outer-container .page-col h3 {\n        font-size: 20px;\n      }\n      .outer-container .page-col p, .text-block {\n        font-size: 14px;\n      }\n     .outer-container .text-block {\n        font-size: 14px;\n      }\n    }\n\n    /* 保持原有haft-div风格细调: 所有文本默认灰色 */\n    .outer-container .small-note {\n      font-size: 0.85rem;\n      color: #6c6c6c;\n    }\n\n    /* 让计算区块更清晰 */\n    .outer-container .formula-line {\n      font-family: monospace;\n      word-break: break-word;\n    }\n  </style>\n \n<div class=\"outer-container\"  style=\"background-color:#000000;padding:15px; display: flex;\n  justify-content: center;\n  align-items: center;\">\n  <div class=\"book-layout\">\n    <!-- 左侧：前半部分内容（Haftungsausschluss + 介绍 + Stromerzeugung + 假设 + CO₂ + 免责说明 + 部分原始结构） -->\n    <div class=\"page-col left-page\">\n      <h3>Haftungsausschluss</h3>\n      \n \n      <div class=\"text-block\">\n        <b>1. Berechnungsgrundlagen:</b><br>\n        Die Berechnung basiert auf typischen Installationsbedingungen in Süddeutschland:\nAusrichtung der Solarmodule: Süden\nNeigungswinkel: 30°–35°\nJährliche Volllaststunden: ca. 1160 h\nEigenverbrauchsquote: Abhängig von der Speicherkonfiguration (je größer der Speicher, desto höher die Quote)\nStrompreis: 0,40 €/kWh\n      </div>\n      \n      <div class=\"text-block\">\n        <b>2. Berechnungsformel:</b><br>\n        <b>Parameter Erläuterung</b><br>\n\t\t\tA: Gesamtleistung der Solarmodule (kW)<br>\n\t\t\tB: Jährliche Sonneneinstrahlung (Volllaststunden), Standard: 1160 h<br>\n\t\t\tC: Eigenverbrauchsquote (%), Standard: 90 %<br>\n\t\t\tD: Strompreis (€/kWh), Standard: 0,40 €<br>\n\t\t\tH: Nutzungsfaktor (%) – abhängig von der Speicherkonfiguration (höherer Faktor bei größerem Speicher)<br>\n\t\t\tF: Kosten (€)<br>\n\t\t\tE: Jährlicher Ertrag (€) = A × B × C × D × H<br>\n\t\t\tG: Amortisationszeit (Jahre) = F ÷ E<br>\n\t\t\t<b>Amortisationszeit</b><br>\n\t\t\tG = F ÷ (A × B × C × D × H）<br>\n      </div>\n      \n\n      \n\n      \n      <div class=\"spacer\"></div>\n    \n    </div>\n\n    <!-- 右侧：后半部分内容（Berechnungsdetails + 完整计算过程 + 公式拆解） -->\n    <div class=\"page-col right-page\">\n      <!-- <h3>Berechnungsdetails</h3 -->\n      \n            <div class=\"text-block\">\n        <b>3. Rechnungen:</b><br>\n        <b>Konfiguration 1</b><br>\n        Produkt: SolidFlex 2000 + SFA1800 + 2000 W Solarmodule<br>\n\t\tKosten: 1598 €<br>\n\t\tJährlicher PV-Ertrag: 2000 W × 1160 h = 2320 kWh<br>\n\t\tJährlicher Ertrag: 2320 kWh × 0,40 € × 90% = 835 €<br>\n\t\tAmortisationszeit: 1598 € ÷ (835 € × 85%) ≈ 2,25 Jahre<br>\n\t\t\n\t\t        <b>Konfiguration 2</b><br>\nProdukt: BK1600 + 890 W Solarmodule<br>\nKosten: 599 €<br>\nJährlicher PV-Ertrag: 890 W × 1160 h = 1032  kWh<br>\nJährlicher Ertrag: 1032 kWh × 0,40 € × 90 % = 317  €<br>\nAmortisationszeit: 599 € ÷ (317 € × 90 %) ≈ 2,1 Jahre<br>\n      </div>\n            <div class=\"text-block\">\n        <b>4. Wichtiger Hinweis:</b><br>\n        Gemäß den deutschen „Plug-in“-Richtlinien darf der Wechselrichter maximal 800 W ins Hausnetz einspeisen.<br><br>\n        Die angegebenen Werte basieren auf idealen Testbedingungen. Die tatsächlichen Einsparungen können je nach Installationsort, individuellen Nutzungsgewohnheiten, Wetterbedingungen und tatsächlicher Systemeffizienz abweichen.\nDie Berechnung dient lediglich zur Orientierung und stellt keine Garantie für tatsächliche Erträge dar.\n      </div>\n  \n      \n      <!-- <hr> -->\n \n    </div>\n  </div>\n</div>",
        "container": "full",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
  },
