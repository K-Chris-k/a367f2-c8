 class=\"category-list\" id=\"category-list\">\n                </ul>\n            </div>\n            <!-- 右侧内容 -->\n            <div class=\"faq-content\">\n                <div class=\"current-category\">\n                    <a href=\"javascript:void(0);\">\n                        <i class=\"fas fa-folder\"></i>\n                        <span id=\"current-category-path\">Alle anzeigen</span>\n                    </a>\n                </div>\n\n\n                <div class=\"faq-list\" id=\"faq-list\">\n                    <div class=\"no-results\" id=\"no-results\">\n                        <i class=\"fas fa-search fa-3x\"></i>\n                        <h3>Wurden keine Ergebnisse gefunden.</h3>\n                        <p>Überprüfen Sie die Rechtschreibung oder verwenden Sie ein anderes Wort oder eine andere\n                            Phrase.\n                        </p>\n                    </div>\n                </div>\n\n                <!-- 分页控件 -->\n                <div class=\"pagination\" id=\"pagination\" style=\"display: none;\">\n                    <button id=\"prev-page\" disabled>\n                        <svg viewBox=\"64 64 896 896\" focusable=\"false\" data-icon=\"left\" width=\"1em\" height=\"1em\"\n                            fill=\"currentColor\" aria-hidden=\"true\">\n                            <path\n                                d=\"M724 218.3V141c0-6.7-7.7-10.4-12.9-6.3L260.3 486.8a31.86 31.86 0 000 50.3l450.8 352.1c5.3 4.1 12.9.4 12.9-6.3v-77.3c0-4.9-2.3-9.6-6.1-12.6l-360-281 360-281.1c3.8-3 6.1-7.7 6.1-12.6z\">\n                            </path>\n                        </svg>\n                    </button>\n                    <div class=\"pagination-numbers\" id=\"pagination-numbers\"></div>\n                    <button id=\"next-page\">\n                        <svg viewBox=\"64 64 896 896\" focusable=\"false\" data-icon=\"right\" width=\"1em\" height=\"1em\"\n                            fill=\"currentColor\" aria-hidden=\"true\">\n                            <path\n                                d=\"M765.7 486.8L314.9 134.7A7.97 7.97 0 00302 141v77.3c0 4.9 2.3 9.6 6.1 12.6l360 281.1-360 281.1c-3.9 3-6.1 7.7-6.1 12.6V883c0 6.7 7.7 10.4 12.9 6.3l450.8-352.1a31.96 31.96 0 000-50.4z\">\n                            </path>\n                        </svg>\n                    </button>\n                    <!-- <div class=\"pagination-info\" id=\"pagination-info\"></div> -->\n                </div>\n            </div>\n        </div>\n\n    </div>\n   <script type=\"text/javascript\">\n   const faqList = document.getElementById(\"faq-list\"),\n   typeList = document.getElementById(\"category-list\"),\n   errorMessage = document.getElementById(\"no-results\"),\n   //    <br>\n   produkteArr = [\n     \"Anwendbare Produkte: SolidFlex 2000、PowerFlex 2000、BK1600、BK1600 Ultra\",\n     \"Anwendbare Produkte: SolidFlex 2000、PowerFlex 2000\",\n     \"Anwendbare Produkte: SolidFlex 2000\",\n     \"Anwendbare Produkte: BK1600、BK1600 Ultra\",\n     \"Anwendbare Produkte: SolidFlex 2000、PowerFlex 2000、BK1600 Ultra\",\n   ],\n   jsonDataType = {\n     types: [\n       { categories: \"Unterschiede & Kompatibilität\", name: \"Unterschiede & Kompatibilität\", childrens: \"\" },\n       { categories: \"Installation & Betriebsumgebung\", name: \"Installation & Betriebsumgebung\", childrens: \"\" },\n       { categories: \"Funktionen & Systembetrieb\", name: \"Funktionen & Systembetrieb\", childrens: \"\" },\n       { categories: \"Sicherheit & Support\", name: \"Sicherheit & Support\", childrens: \"\" },\n     ],\n   },\n   jsonData = {\n     contents: [\n       {\n         categories: \"Unterschiede & Kompatibilität\",\n         question: \"Was ist der Unterschied zwischen dem SolidFlex 1200 und dem SolidFlex 2000 – außer der Wechselstromleistung?\",\n         answer:\n           \"Der SolidFlex 1200 kommt ohne LoRa-Funktion, unterstützt aber 2,4 GHz und 5 GHz WLAN. Ein LAN-Modul ist nicht integriert.<br>Der SolidFlex 2000 bietet LoRa, arbeitet im 2,4‑GHz‑WLAN und kann optional um ein LAN‑Modul erweitert werden.\",\n       },\n       {\n         categories: \"Unterschiede & Kompatibilität\",\n         question: \"Kann ich meinen Mikro-Wechselrichter mit dem SolidFlex 1200 nutzen?\",\n         answer:\n           \"Ja, du hast zwei Möglichkeiten:<br>1. Schließe deinen Mikro-Wechselrichter direkt an den Off‑Grid‑Ausgang des SolidFlex 1200 an. Achte dabei darauf, dass die Ausgangsleistung 1200W nicht überschreitet.<br>2. Nutze einen Smart Meter, um deinen Überschuss zu erfassen – das System speichert ihn automatisch, ohne dass du deine bestehende PV‑Anlage ändern musst.\",\n       },\n  \n       {\n         categories: \"Unterschiede & Kompatibilität\",\n         question: \"Welche Smart Meter und Wechselrichter werden unterstützt?\",\n         answer:\n           \"Wir arbeiten kontinuierlich daran, immer mehr Geräte anzubinden. Aktuell sind folgende Marken kompatibel:<br>Smart Meter: Shelly, everHome, Solarman, HomeWizard, Stormesler<br>Wechselrichter: Deye, FusionSolar, GOODWE, GROWATT, SolarEdge, SolaX\",\n       },\n       {\n         categories: \"Unterschiede & Kompatibilität\",\n         question: \"Kann ich das System in Home Assistant einbinden?\",\n         answer:\n           \"Ja, du kannst den SolidFlex 1200 direkt in Home Assistant integrieren. Über die offene API lässt er sich auch in andere Smart‑Home‑Plattformen einbinden.\",\n       },\n       {\n         categories: \"Unterschiede & Kompatibilität\",\n         question: \"Kann ich mehrere Solarmodule an denselben MPPT anschließen?\",\n         answer:\n           \"Ja, wir empfehlen eine Parallelschaltung – der MPPT regelt den Strom automatisch. Vermeide eine Reihenschaltung, damit die Spannung 60V nicht überschreitet.Für maximale Effizienz kannst du die Gesamtleistung der beiden Module auf etwa das 1,2‑ bis 1,5‑Fache der Geräteleistung auslegen (ca. 720–900W).\",\n       },\n       {\n         categories: \"Unterschiede & Kompatibilität\",\n         question: \"Kann ich verschiedene Erweiterungsakkus mischen?\",\n         answer:\n           \"Ja, dank der BatteryFlex‑Technologie kannst du die PFA‑ und SFA‑Akkus beliebig kombinieren. Insgesamt sind bis zu fünf Akkupacks möglich.\",\n       },\n       \n       {\n           categories: \"Installation & Betriebsumgebung\",\n           question: \"Wo kann ich das Gerät aufstellen?\",\n           answer:\n             \"Du kannst den SolidFlex 1200 sowohl drinnen als auch draußen installieren. Achte dabei auf folgende Punkte:<br>1. Die Umgebungstemperatur sollte idealerweise zwischen 15 °C und 30 °C liegen.<br>2. Sorge für eine stabile WLAN‑Verbindung.<br>3. Halte auf der Rückseite mindestens 5 cm Abstand zur Wand, damit die Luft zirkulieren kann.<br>4. Stelle das Gerät nicht in der Nähe von brennbaren oder explosiven Gegenständen auf.\",\n         },\n  \n       {\n         categories: \"Installation & Betriebsumgebung\",\n         question: \"Kann ich das System auch im Winter nutzen?\",\n         answer:\n           \"Ja, der SolidFlex 1200 heizt sich bei Bedarf selbst: Sinkt die Temperatur unter 1°C, startet automatisch die integrierte Heizung.<br>Damit der Akku auch bei Kälte zuverlässig arbeitet, empfehlen wir:<br>Im Alltag einen Ladezustand von mindestens 30–50 % einzuplanen.<br>Bei Schnee oder extremem Wetter einen Ladezustand über 70 % für ausreichend Reserve.\",\n       },\n       {\n         categories: \"Installation & Betriebsumgebung\",\n         question: \"Ich habe noch keine Erfahrung mit PV – ist das System trotzdem einfach zu nutzen?\",\n         answer:\n           \"Absolut. Du schließt das Gerät einfach an eine normale Haushaltssteckdose an und steuerst es bequem über die App.<br>Wenn du mal eine Frage hast, helfen dir unsere Tutorials auf YouTube oder die Hilfeseiten auf der Website weiter. Du kannst uns aber auch jederzeit per E‑Mail oder über die sozialen Medien kontaktieren.\",\n       },\n       {\n         categories: \"Funktionen & Systembetrieb\",\n         question: \"Kann ich das System auch ohne Internet nutzen?\",\n         answer:\n           \"Ja, du hast zwei Möglichkeiten für den lokalen Betrieb:<br>1. Lokaler Netzwerkbetrieb: Ist der Smart Meter einmal mit dem Gerät gekoppelt und im selben Netzwerk konfiguriert, arbeitet das System auch ohne Internetverbindung zuverlässig weiter.<br>2. Bluetooth‑Steuerung: Du kannst dich direkt per Bluetooth mit dem Gerät verbinden und es lokal steuern.\",\n       },\n       {\n         categories: \"Funktionen & Systembetrieb\",\n         question: \"Funktioniert der SolidFlex 1200 auch bei einem Stromausfall?\",\n         answer:\n           \"Ja. Das Gerät hat eine integrierte EPS‑Notstromfunktion. Bei einem Stromausfall versorgst du deine wichtigsten Geräte einfach über den Off‑Grid‑Ausgang – mit einer maximalen Leistung von 1200 W.\",\n       },\n       {\n         categories: \"Funktionen & Systembetrieb\",\n         question: \"Was macht der Smart Meter eigentlich?\",\n         answer:  \n           \"Der Smart Meter übernimmt drei wichtige Aufgaben:<br>1. Er misst deinen aktuellen Stromverbrauch und hilft dem System, intelligent zu laden oder zu entladen.<br>2. Er erfasst den Überschuss deiner PV‑Anlage – dieser wird gespeichert, ohne dass Strom ins Netz zurückfließt.<br>3. Er dient als Datenquelle für deine PV‑Anlage und übermittelt wichtige Betriebsdaten.\",\n       },\n       {\n         categories: \"Funktionen & Systembetrieb\",\n         question: \"Und wofür ist der Smart Plug gut?\",\n         answer: \"Den Smart Plug steckst du einfach in eine Haushaltssteckdose und schließt dein Gerät daran an. Er misst dessen Leistungsaufnahme – das INDEVOLT‑System kann dann automatisch darauf reagieren und passend entladen.\",\n       },\n       {\n         categories: \"Funktionen & Systembetrieb\",\n         question: \"Wie arbeitet das System im Alltag?\",\n         answer: \"Im Selbstverbrauchsmodus nutzt du deinen Solarstrom tagsüber direkt. Überschüsse werden gespeichert und stehen dir abends zur Verfügung.<br>In der App kannst du außerdem verschiedene Betriebsmodi wählen, um das System genau an deine Gewohnheiten anzupassen.\",\n       },\n       {\n         categories: \"Sicherheit & Support\",\n         question: \"Was wurde getan, damit das System sicher ist?\",\n         answer:\n           \"Sicherheit hat bei uns oberste Priorität. Der SolidFlex 1200 bietet daher:<br>1. Sichere Batterietechnologie: Halbfeste Zellen, die auch im Fehlerfall rauch‑ und feuerfrei bleiben.<br>2. Intelligentes Batteriemanagement (BMS): Es überwacht permanent alle Werte und greift bei Bedarf schützend ein.<br>3. Passive Sicherheit: Nicht mit dem Hauptgerät verbundene Akkupacks sind im 0‑V‑Zustand – sicher auch bei versehentlichem Kontakt.<br>4. Robustes Gehäuse: Das Aluminiumgehäuse ist besonders widerstandsfähig und brandschutzoptimiert.<br>5. Hohe Schutzart: Mit IP65 ist das Gerät staubdicht und strahlwassergeschützt – ideal für den Außenbereich.\",\n       },\n       {\n         categories: \"Sicherheit & Support\",\n         question: \"Was tun, wenn ich ein Problem habe?\",\n         answer:\n           \"Wir helfen dir schnell und unkompliziert. Kontaktiere uns einfach über einen der folgenden Wege:<br>Soziale Medien: Discord, WhatsApp, Facebook<br>E‑Mail: <a target='_blank' href='https://de.indevolt.com/pages/contact-us/'>service@indevolt.com</a><br>Live‑Chat auf unserer Website<br>Du kannst dich auch gerne mit anderen Nutzern in unserer Community austauschen – viele Fragen lassen sich dort direkt beantworten.\",\n       },\n       {\n         categories: \"Sicherheit & Support\",\n         question: \"Wie pflege ich meine Batterie am besten?\",\n         answer:\n           \"Damit dir dein Speicher lange Freude bereitet:<br>1. Aktiviere Tiefen‑Standby‑Modus, um unnötigen Energieverbrauch zu vermeiden.<br>2. Führe etwa alle 15 Tage eine Volladung durch – so bleibt die Zustandsanzeige (SOC) genau.<br>3. Plane einen Backup-SOC von mindestens 10% ein, um Tiefentladung zu vermeiden und die Lebensdauer zu verlängern.\",\n       },\n     ],\n   };\n\n document.addEventListener(\"DOMContentLoaded\", function () {\n   typesFromJSON(jsonDataType);\n   generateListFromJSON(jsonData, function () {\n     const faqItems = document.querySelectorAll(\".faq-item\"),\n       searchInput = document.getElementById(\"search-input\"),\n       searchBtn = document.getElementById(\"search-btn\"),\n       categoryItems = document.querySelectorAll(\".category-item\"),\n       subItems = document.querySelectorAll(\".sub-item\"),\n       noResults = document.getElementById(\"no-results\"),\n       pagination = document.getElementById(\"pagination\"),\n       prevPageBtn = document.getElementById(\"prev-page\"),\n       nextPageBtn = document.getElementById(\"next-page\"),\n       paginationNumbers = document.getElementById(\"pagination-numbers\"),\n       currentCategoryPath = document.getElementById(\"current-category-path\");\n\n     let currentPage = 1;\n     const itemsPerPage = 9;\n     let currentVisibleItems = [];\n\n     document.getElementById(\"current-category-path\").addEventListener(\"click\", function (e) {\n       searchInput.value = \"\";\n       clearAllActive();\n       currentCategoryPath.textContent = \"Alle anzeigen\";\n       currentPage = 1;\n       performSearch();\n     });\n\n     faqItems.forEach((item) => {\n       item.querySelector(\".faq-question\").addEventListener(\"click\", () => {\n         item.classList.toggle(\"active\");\n       });\n     });\n\n     categoryItems.forEach((item) => {\n       const chevron = item.querySelector(\".fa-chevron-down\");\n       console.log(chevron);\n       const title = item.querySelector(\".category-title\");\n       chevron &&\n         title &&\n         title.addEventListener(\"click\", function (e) {\n           e.stopPropagation();\n           item.classList.toggle(\"expanded\");\n         });\n       item.addEventListener(\"click\", function (e) {\n         (!e.target.closest(\".category-title\") || !chevron) &&\n           (clearAllActive(),\n           item.classList.add(\"active\"),\n           (currentCategoryPath.textContent = item.querySelector(\"span\").textContent),\n           console.log(currentCategoryPath),\n           (currentPage = 1),\n           performSearch());\n       });\n     });\n\n     subItems.forEach((item) => {\n       item.addEventListener(\"click\", function (e) {\n         e.stopPropagation();\n         clearAllActive();\n         item.classList.add(\"active\");\n         const parentCategory = item.closest(\".category-item\");\n         if (parentCategory) {\n           const parentName = parentCategory.querySelector(\".category-title span\").textContent,\n             subName = item.querySelector(\"span\").textContent;\n           currentCategoryPath.textContent = `${parentName} > ${subName}`;\n         } else currentCategoryPath.textContent = item.querySelector(\"span\").textContent;\n         currentPage = 1;\n         performSearch();\n       });\n     });\n\n     function clearAllActive() {\n       categoryItems.forEach((i) => i.classList.remove(\"active\"));\n       subItems.forEach((i) => i.classList.remove(\"active\"));\n     }\n\n     function updatePagination(totalItems) {\n       const totalPages = Math.ceil(totalItems / itemsPerPage);\n       if (totalPages <= 1 || totalItems === 0) {\n         pagination.style.display = \"none\";\n         return;\n       }\n       if (\n         ((pagination.style.display = \"flex\"),\n         (prevPageBtn.disabled = currentPage === 1),\n         (nextPageBtn.disabled = currentPage === totalPages),\n         (paginationNumbers.innerHTML = \"\"),\n         totalPages <= 6)\n       )\n         for (let i = 1; i <= totalPages; i++) createPageNumber(i);\n       else if (currentPage <= 3) {\n         for (let i = 1; i <= 4; i++) createPageNumber(i);\n         createEllipsis();\n         createPageNumber(totalPages);\n       } else if (currentPage >= totalPages - 2) {\n         createPageNumber(1);\n         createEllipsis();\n         for (let i = totalPages - 3; i <= totalPages; i++) createPageNumber(i);\n       } else {\n         createPageNumber(1);\n         createEllipsis();\n         for (let i = currentPage - 1; i <= currentPage + 1; i++) createPageNumber(i);\n         createEllipsis();\n         createPageNumber(totalPages);\n       }\n\n       function createPageNumber(page) {\n         const pageNumber = document.createElement(\"div\");\n         (pageNumber.className = \"pagination-number\"),\n           page === currentPage && pageNumber.classList.add(\"active\"),\n           (pageNumber.textContent = page),\n           pageNumber.addEventListener(\"click\", () => {\n             currentPage = page;\n             displayCurrentPage();\n           }),\n           paginationNumbers.appendChild(pageNumber);\n       }\n\n       function createEllipsis() {\n         const ellipsis = document.createElement(\"div\");\n         (ellipsis.className = \"pagination-ellipsis\"),\n           (ellipsis.textContent = \"...\"),\n           paginationNumbers.appendChild(ellipsis);\n       }\n     }\n\n     function highlightText(element, text) {\n       if (!text || !element) return;\n       const innerHTML = element.innerHTML,\n         index = innerHTML.toLowerCase().indexOf(text.toLowerCase());\n       index >= 0 &&\n         (element.innerHTML =\n           innerHTML.substring(0, index) +\n           \"<span class='highlight'>\" +\n           innerHTML.substring(index, index + text.length) +\n           \"</span>\" +\n           innerHTML.substring(index + text.length));\n     }\n\n     function displayCurrentPage() {\n       faqItems.forEach((item) => {\n         item.style.display = \"none\";\n       });\n       const totalItems = currentVisibleItems.length,\n         startIndex = (currentPage - 1) * itemsPerPage,\n         endIndex = Math.min(startIndex + itemsPerPage, totalItems);\n       for (let i = startIndex; i < endIndex; i++) {\n         const item = currentVisibleItems[i];\n         item.style.display = \"block\";\n       }\n       updatePagination(totalItems);\n     }\n\n     function performSearch() {\n       var searchTerm = searchInput.value.toLowerCase().trim();\n       searchTerm = searchTerm\n         .replace(/sf2000/gi, \"SolidFlex 2000\")\n         .replace(/sf 2000/gi, \"SolidFlex 2000\")\n         .replace(/solidflex2000/gi, \"SolidFlex 2000\")\n         .replace(/solid flex 2000/gi, \"SolidFlex 2000\")\n         .replace(/solid flex2000/gi, \"SolidFlex 2000\")\n         .replace(/pf2000/gi, \"PowerFlex 2000\")\n         .replace(/pf 2000/gi, \"PowerFlex 2000\")\n         .replace(/power flex 2000/gi, \"PowerFlex 2000\")\n         .replace(/power flex2000/gi, \"PowerFlex 2000\")\n         .replace(/powerflex2000/gi, \"PowerFlex 2000\")\n         .replace(/bk 1600/gi, \"BK1600\")\n         .toLowerCase();\n       const activeItem = document.querySelector(\".category-item.active, .sub-item.active\"),\n         activeCategoryId = activeItem ? activeItem.getAttribute(\"data-category\") : \"all\";\n       if (\n         (currentVisibleItems = []),\n         faqItems.forEach((item) => {\n           item.querySelectorAll(\".highlight\").forEach((hl) => {\n             const parent = hl.parentNode;\n             parent.replaceChild(document.createTextNode(hl.textContent), hl);\n             parent.normalize();\n           });\n           const question = item.querySelector(\".faq-question span\").textContent.toLowerCase(),\n             answer = item.querySelector(\".faq-answer\").textContent.toLowerCase(),\n             categories = item.getAttribute(\"data-categories\").split(\",\"),\n             isCategoryMatch = activeCategoryId === \"all\" || categories.includes(activeCategoryId),\n             isSearchMatch = searchTerm === \"\" || question.includes(searchTerm) || answer.includes(searchTerm);\n           isCategoryMatch && isSearchMatch && currentVisibleItems.push(item);\n         }),\n         displayCurrentPage(),\n         searchTerm.length > 0\n       ) {\n         const startIndex = (currentPage - 1) * itemsPerPage,\n           endIndex = Math.min(startIndex + itemsPerPage, currentVisibleItems.length);\n         for (let i = startIndex; i < endIndex; i++) {\n           const item = currentVisibleItems[i];\n           highlightText(item.querySelector(\".faq-question span\"), searchTerm);\n           highlightText(item.querySelector(\".faq-answer p\"), searchTerm);\n           const answerSpan = item.querySelector(\".faq-answer span\");\n           answerSpan && highlightText(answerSpan, searchTerm);\n         }\n       }\n       noResults.style.display = currentVisibleItems.length === 0 ? \"block\" : \"none\";\n     }\n\n     prevPageBtn.addEventListener(\"click\", () => {\n       currentPage > 1 && (currentPage--, displayCurrentPage());\n     });\n\n     nextPageBtn.addEventListener(\"click\", () => {\n       const totalPages = Math.ceil(currentVisibleItems.length / itemsPerPage);\n       currentPage < totalPages && (currentPage++, displayCurrentPage());\n     });\n\n     searchInput.addEventListener(\"input\", () => {\n       currentPage = 1;\n       performSearch();\n     });\n\n     searchBtn.addEventListener(\"click\", () => {\n       currentPage = 1;\n       performSearch();\n     });\n\n     performSearch();\n   });\n });\n\n function typesFromJSON(data) {\n   typeList.innerHTML = \"\";\n   data.types.forEach((type) => {\n     const typeLi = document.createElement(\"li\");\n     typeLi.dataset.category = type.categories;\n     typeLi.className = \"category-item\";\n     const typeDIV = document.createElement(\"div\");\n     typeDIV.className = \"category-title\";\n     const typechlDIV = document.createElement(\"div\");\n     typechlDIV.className = \"category-box\";\n     const i = document.createElement(\"i\");\n     i.className = \"fas fas-flex\";\n     i.innerHTML = `<svg class=\"icon icon-slider-prev icon--small\"  width=\"15\" height=\"15\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n   <path d=\"M7.5 3.74121L13.75 9.99121L7.5 16.2412\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n </svg>`;\n     const span = document.createElement(\"span\");\n     span.textContent = type.name;\n     const hasChli = document.createElement(\"i\");\n     if (\n       ((hasChli.className = \"fas fa-chevron-down\"),\n       typechlDIV.appendChild(span),\n       typechlDIV.appendChild(i),\n       typeDIV.appendChild(typechlDIV),\n       type.childrens && Array.isArray(type.childrens) && typeDIV.appendChild(hasChli),\n       typeLi.appendChild(typeDIV),\n       type.childrens && Array.isArray(type.childrens))\n     ) {\n       const chiUl = document.createElement(\"ul\");\n       chiUl.className = \"subcategory\";\n       type.childrens.forEach((children) => {\n         const childrenLi = document.createElement(\"li\");\n         childrenLi.dataset.category = children.categories;\n         childrenLi.className = \"sub-item\";\n         const childrenLiDIV = document.createElement(\"div\"),\n           childrenLiDIVi = document.createElement(\"i\");\n         childrenLiDIVi.className = \"fas\";\n         const childrenLiDIVspan = document.createElement(\"span\");\n         (childrenLiDIVspan.textContent = children.name),\n           childrenLiDIV.appendChild(childrenLiDIVi),\n           childrenLiDIV.appendChild(childrenLiDIVspan),\n           childrenLi.appendChild(childrenLiDIV),\n           chiUl.appendChild(childrenLi);\n       });\n       typeLi.appendChild(chiUl);\n     }\n     typeList.appendChild(typeLi);\n   });\n }\n\n function generateListFromJSON(data, cb) {\n   try {\n     if (!data || !data.contents || !Array.isArray(data.contents))\n       throw new Error(\"无效的JSON数据格式\");\n     data.contents.forEach((content) => {\n       const itemDIV = document.createElement(\"div\");\n       itemDIV.dataset.categories = content.categories;\n       itemDIV.className = \"faq-item\";\n       const questionDIV = document.createElement(\"div\");\n       questionDIV.className = \"faq-question\";\n       const span = document.createElement(\"span\");\n       span.textContent = content.question;\n       const i = document.createElement(\"i\");\n       questionDIV.appendChild(span);\n       questionDIV.appendChild(i);\n       const answerDIV = document.createElement(\"div\");\n       answerDIV.className = \"faq-answer\";\n       const answerP = document.createElement(\"p\");\n       if (\n         ((answerP.innerHTML = content.answer),\n         answerDIV.appendChild(answerP),\n         content.produkte)\n       ) {\n         const answerP2 = document.createElement(\"span\");\n         (answerP2.className = \"faq-answer-produkte\"),\n           (answerP2.innerHTML = \"<br>\" + produkteArr[content.produkte]),\n           answerDIV.appendChild(answerP2);\n       }\n       itemDIV.appendChild(questionDIV),\n         itemDIV.appendChild(answerDIV),\n         faqList.appendChild(itemDIV);\n     });\n   } catch (error) {\n     showError(\"ERROR: \" + error.message);\n   }\n   cb();\n }\n\n function showError(message) {\n   errorMessage.textContent = message;\n   errorMessage.style.display = \"block\";\n }\n \n   </script>\n</body>\n</html>",
